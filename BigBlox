-- ║    INSTANT INTERACT PROMPT       ║
-- ╚══════════════════════════════════╝
local instantConn
local function applyInstantInteract(enabled)
    if enabled then
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ProximityPrompt") then v.HoldDuration = 0 end
        end
        instantConn = workspace.DescendantAdded:Connect(function(v)
            if Config.InstantInteract and v:IsA("ProximityPrompt") then
                v.HoldDuration = 0
            end
        end)
    else
        if instantConn then instantConn:Disconnect() instantConn = nil end
    end
end

-- ╔══════════════════════════════════╗
-- ║           SHOW CHAT              ║
-- ╚══════════════════════════════════╝
local function applyShowChat(value)
    _G.showChat = value
    if value then
        task.spawn(function()
            while _G.showChat and task.wait() do
                pcall(function()
                    local tcs = game:GetService("TextChatService")
                    local cfg  = tcs:FindFirstChildOfClass("ChatWindowConfiguration")
                    if cfg then cfg.Enabled = true end
                end)
            end
        end)
    else
        _G.showChat = false
        pcall(function()
            if workspace:FindFirstChild("Players")
            and workspace.Players:FindFirstChild("Spectating")
            and not workspace.Players.Spectating:FindFirstChild(LocalPlayer.Name) then
                local tcs = game:GetService("TextChatService")
                local cfg  = tcs:FindFirstChildOfClass("ChatWindowConfiguration")
                if cfg then cfg.Enabled = false end
            end
        end)
    end
end


