-- ║           AUTO MAPA              ║
-- ╚══════════════════════════════════╝
local provaCoords = {
    ProvaDosHexagonos = Vector3.new(-965, 100, 713),
    ProvaDosSocos     = Vector3.new(-965, 100, 713),
    ProvaFabrica      = Vector3.new(140, 21, 526),
}

local function equipFirstItem()
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    if not backpack then return nil end
    local tool, elapsed = nil, 0
    repeat
        tool = backpack:FindFirstChildOfClass("Tool")
        if not tool then task.wait(0.2) end
        elapsed = elapsed + 0.2
    until tool or elapsed > 30
    if not tool then return nil end
    task.wait(5)
    tool = backpack:FindFirstChildOfClass("Tool")
    if not tool then return nil end
    local hum = LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
    if hum then hum:EquipTool(tool) end
    return tool
end

local function clickOnPart(part)
    local cam = workspace.CurrentCamera
    if not cam or not part then return end
    local screenPos, onScreen = cam:WorldToScreenPoint(part.Position)
    if not onScreen then return end
    pcall(function()
        mousemoveabs(screenPos.X, screenPos.Y)
        mouse1click()
    end)
end

local cozinhaConnections = {}
local function connectCozinha(cozinha)
    for _, c in ipairs(cozinhaConnections) do c:Disconnect() end
    cozinhaConnections = {}

    local spawns = cozinha:FindFirstChild("Spawns")
    if not spawns then return end

    local function watchPart(part)
        if part.Name ~= "Part" then return end
        local conn = part.ChildAdded:Connect(function(child)
            if not Config.AutoProva then return end
            if not child:IsA("Model") or child.Name == "Bomb" then return end

            local char = LocalPlayer.Character
            if not (char and char:FindFirstChildOfClass("Tool")) then
                task.spawn(equipFirstItem)
                local waited = 0
                repeat
                    task.wait(0.1)
                    waited = waited + 0.1
                    char = LocalPlayer.Character
                until (char and char:FindFirstChildOfClass("Tool")) or waited > 10
            end

            task.spawn(function()
                while Config.AutoProva and child and child.Parent == part do
                    clickOnPart(part)
                    task.wait(0.1)
                end
            end)
        end)
        table.insert(cozinhaConnections, conn)
    end

    for _, child in ipairs(spawns:GetChildren()) do watchPart(child) end
    table.insert(cozinhaConnections, spawns.ChildAdded:Connect(watchPart))
end

local autoProvaRunning = false
local function autoProvaLoop()
    if autoProvaRunning then return end
    autoProvaRunning = true
    task.spawn(function()
        while Config.AutoProva do
            local prova = workspace:FindFirstChild("Prova")
            if prova then
                local cozinha = prova:FindFirstChild("Prova_Cozinha")
                if cozinha then
                    connectCozinha(cozinha)
                    while Config.AutoProva and prova:FindFirstChild("Prova_Cozinha") do
                        task.wait(0.5)
                    end
                    for _, c in ipairs(cozinhaConnections) do c:Disconnect() end
                    cozinhaConnections = {}
                else
                    removeSafePlatform()
                    for _, modelo in ipairs(prova:GetChildren()) do
                        if modelo:IsA("Model") and provaCoords[modelo.Name] then
                            local pos = provaCoords[modelo.Name]
                            createSafePlatform(pos)
                            teleport(pos)
                            break
                        end
                    end
                end
            end
            task.wait(0.5)
        end
        removeSafePlatform()
        autoProvaRunning = false
    end)
end

