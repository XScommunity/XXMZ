local safePlatform
local function createSafePlatform(pos)
    if safePlatform then safePlatform:Destroy() end
    local p = Instance.new("Part")
    p.Name         = "SafePlatform"
    p.Anchored     = true
    p.CanCollide   = true
    p.Transparency = 1
    p.Size         = Vector3.new(20, 1, 20)
    p.CFrame       = CFrame.new(pos - Vector3.new(0, 2.5, 0))
    p.Parent       = workspace
    safePlatform   = p
end

local function removeSafePlatform()
    if safePlatform then safePlatform:Destroy() safePlatform = nil end
end

