-- ║     AUTO CLICK (MOUSE PURO)      ║
-- ╚══════════════════════════════════╝
local lastClick = 0
RunService.Heartbeat:Connect(function()
    if not Config.AutoClick then return end
    local now = tick()
    if now - lastClick < 0.05 then return end
    lastClick = now
    pcall(mouse1click)
end)

