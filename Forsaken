-- Void Rush Control
local voidRushEnabled = false
local voidRushConnection = nil
local ORIGINAL_DASH_SPEED = 60

local function setupCharacter(character)
    local Humanoid = character:WaitForChild("Humanoid")
    local HumanoidRootPart = character:WaitForChild("HumanoidRootPart")
    _G.VoidRush_Humanoid = Humanoid
    _G.VoidRush_HumanoidRootPart = HumanoidRootPart
end

local isOverrideActive = false
local overrideConnection

local function startVoidRushOverride()
    if isOverrideActive then return end
    isOverrideActive = true

    overrideConnection = RunService.RenderStepped:Connect(function()
        local humanoid = _G.VoidRush_Humanoid
        local rootPart = _G.VoidRush_HumanoidRootPart
        if not humanoid or not rootPart then return end
    
        humanoid.WalkSpeed = ORIGINAL_DASH_SPEED
        humanoid.AutoRotate = false
    
        local direction = rootPart.CFrame.LookVector
        local horizontal = Vector3.new(direction.X, 0, direction.Z)
        if horizontal.Magnitude > 0 then
            humanoid:Move(horizontal.Unit)
        end
    end)
end

local function stopVoidRushOverride()
    if not isOverrideActive then return end
    isOverrideActive = false
    
    local humanoid = _G.VoidRush_Humanoid
    
    if humanoid then
        humanoid.WalkSpeed = 16
        humanoid.AutoRotate = true
        humanoid:Move(Vector3.new(0, 0, 0))
    end
    
    if overrideConnection then
        overrideConnection:Disconnect()
        overrideConnection = nil
    end
end

KillerGroupbox:AddToggle("VoidRushControl", {
    Text = "Void Rush Control",
    Tooltip = "Controla o Void Rush do Noli manualmente",
    Default = false,
    Callback = function(state)
        voidRushEnabled = state
        
        if state then
            -- Setup character inicial
            if LocalPlayer.Character then
                setupCharacter(LocalPlayer.Character)
            end
            
            -- Monitora quando character é adicionado
            LocalPlayer.CharacterAdded:Connect(function(character)
                if voidRushEnabled then
                    setupCharacter(character)
                end
            end)
            
            -- Loop principal
            voidRushConnection = RunService.RenderStepped:Connect(function()
                if not voidRushEnabled then return end
                
                local char = _G.VoidRush_Humanoid and _G.VoidRush_Humanoid.Parent
                local voidRushState = char and char:GetAttribute("VoidRushState")

                if voidRushState == "Dashing" then
                    startVoidRushOverride()
                else
                    stopVoidRushOverride()
                end
            end)
        else
            stopVoidRushOverride()
            if voidRushConnection then
                voidRushConnection:Disconnect()
                voidRushConnection = nil
            end
        end
    end
})

