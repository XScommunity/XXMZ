-- Função que ATUALIZA os valores dos labels
local function updatePlayerStats(playerName)
    disconnectAllStats()
    
    local player = Players:FindFirstChild(playerName)
    if not player then
        Library:Notify({
            Title = "Erro",
            Description = "Jogador não encontrado!",
            Time = 3,
        })
        return
    end

    local playerData = player:FindFirstChild("PlayerData")
    if not playerData then
        Library:Notify({
            Title = "Erro", 
            Description = "PlayerData não encontrado!",
            Time = 3,
        })
        return
    end

    local stats = playerData:FindFirstChild("Stats")
    if not stats then
        Library:Notify({
            Title = "Erro",
            Description = "Stats não encontrado!",
            Time = 3,
        })
        return
    end

    -- Atualiza Tempo Jogado
    local general = stats:FindFirstChild("General")
    if general and general:FindFirstChild("TimePlayed") then
        local timePlayed = general.TimePlayed
        StatsLabels.timePlayed:SetText("⏱️ Tempo: " .. formatTime(timePlayed.Value))
        
        local conn = timePlayed.Changed:Connect(function(newValue)
            StatsLabels.timePlayed:SetText("⏱️ Tempo: " .. formatTime(newValue))
        end)
        table.insert(statsConnections, conn)
    end
    
    -- Atualiza Killer Stats
    local killerStats = stats:FindFirstChild("KillerStats")
    if killerStats then
        for _, stat in pairs(killerStats:GetChildren()) do
            if stat:IsA("NumberValue") or stat:IsA("IntValue") then
                local labelKey = "killer_" .. stat.Name
                if StatsLabels[labelKey] then
                    StatsLabels[labelKey]:SetText(stat.Name .. ": " .. tostring(stat.Value))
                    
                    local conn = stat.Changed:Connect(function(newValue)
                        StatsLabels[labelKey]:SetText(stat.Name .. ": " .. tostring(newValue))
                    end)
                    table.insert(statsConnections, conn)
                end
            end
        end
    end
    
    -- Atualiza Survivor Stats
    local survivorStats = stats:FindFirstChild("SurvivorStats")
    if survivorStats then
        for _, stat in pairs(survivorStats:GetChildren()) do
            if stat:IsA("NumberValue") or stat:IsA("IntValue") then
                local labelKey = "survivor_" .. stat.Name
                if StatsLabels[labelKey] then
                    StatsLabels[labelKey]:SetText(stat.Name .. ": " .. tostring(stat.Value))
                    
                    local conn = stat.Changed:Connect(function(newValue)
                        StatsLabels[labelKey]:SetText(stat.Name .. ": " .. tostring(newValue))
                    end)
                    table.insert(statsConnections, conn)
                end
            end
        end
    end
    
    -- Atualiza Equipped Info
    local equipped = playerData:FindFirstChild("Equipped")
    if equipped then
        local equippedKiller = equipped:FindFirstChild("Killer")
        if equippedKiller then
            for _, item in pairs(equippedKiller:GetChildren()) do
                if item:IsA("StringValue") then
                    local labelKey = "killerequip_" .. item.Name
                    if not StatsLabels[labelKey] then
                        StatsLabels[labelKey] = StatsGroupbox:AddLabel(item.Name .. ": " .. tostring(item.Value), true, labelKey)
                    else
                        StatsLabels[labelKey]:SetText(item.Name .. ": " .. tostring(item.Value))
                    end
                    
                    local conn = item.Changed:Connect(function(newValue)
                        if StatsLabels[labelKey] then
                            StatsLabels[labelKey]:SetText(item.Name .. ": " .. tostring(newValue))
                        end
                    end)
                    table.insert(statsConnections, conn)
                end
            end
        end
        
        local equippedSurvivor = equipped:FindFirstChild("Survivor")
        if equippedSurvivor then
            for _, item in pairs(equippedSurvivor:GetChildren()) do
                if item:IsA("StringValue") then
                    local labelKey = "survivorequip_" .. item.Name
                    if not StatsLabels[labelKey] then
                        StatsLabels[labelKey] = StatsGroupbox:AddLabel(item.Name .. ": " .. tostring(item.Value), true, labelKey)
                    else
                        StatsLabels[labelKey]:SetText(item.Name .. ": " .. tostring(item.Value))
                    end
                    
                    local conn = item.Changed:Connect(function(newValue)
                        if StatsLabels[labelKey] then
                            StatsLabels[labelKey]:SetText(item.Name .. ": " .. tostring(newValue))
                        end
                    end)
                    table.insert(statsConnections, conn)
                end
            end
        end
    end

    Library:Notify({
        Title = "Stats Carregados",
        Description = "Stats de " .. playerName .. " carregados!",
        Time = 3,
    })
end

