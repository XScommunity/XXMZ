local function getMainWeaponName()
    local ok, wName = pcall(function()
        local val = plr.Marketplace["Main Weapon"].Equipped.Value
        return val ~= "Default" and val or "Bat"
    end)
    return ok and wName or "Bat"
end

HumanBox:AddButton({
    Text = "Equip ur weapon",
    Tooltip = "Pega a arma principal automaticamente (teleporte inteligente)",
    Func = function()
        local hrp = plr.Character and plr.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local wName = getMainWeaponName()
        local backpack = plr.Backpack
        local humanoid = plr.Character:FindFirstChildOfClass("Humanoid")

        if backpack:FindFirstChild(wName) then
            if humanoid then
                humanoid:EquipTool(backpack[wName])
            end
            Library:Notify({
                Title = "Equip Weapon",
                Description = "Equipped " .. wName .. " from backpack!",
                Time = 3,
            })
            return
        end

        if plr.Character:FindFirstChild(wName) then
            Library:Notify({
                Title = "Equip Weapon",
                Description = "You already have " .. wName .. " equipped!",
                Time = 3,
            })
            return
        end

        local vendorHitbox = workspace.Map.HumanBase.Vendor.BatCollection.HitBox
        local detector = workspace.Map.HumanBase.Vendor.BatCollection.ClickDetector

        local oldPos = hrp.CFrame
        local startTime = tick()

        Library:Notify({
            Title = "Equip Weapon",
            Description = "Teleporting to vendor...",
            Time = 2,
        })

        repeat
            task.wait()
            if not plr.Character or not plr.Character:FindFirstChild("HumanoidRootPart") then
                Library:Notify({
                    Title = "Equip Weapon",
                    Description = "Character lost, aborting!",
                    Time = 3,
                })
                return
            end
            hrp = plr.Character.HumanoidRootPart
            hrp.CFrame = vendorHitbox.CFrame + Vector3.new(0, 3, 0)
            detector.MaxActivationDistance = 9e9
            fireclickdetector(detector)
        until backpack:FindFirstChild(wName) or tick() - startTime > 5

        if backpack:FindFirstChild(wName) then
            humanoid = plr.Character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                humanoid:EquipTool(backpack[wName])
            end
            Library:Notify({
                Title = "Equip Weapon",
                Description = "Got " .. wName .. "! Teleporting back...",
                Time = 2,
            })
        else
            Library:Notify({
                Title = "Equip Weapon",
                Description = "Failed to get weapon (timeout)!",
                Time = 3,
            })
        end

        task.wait(0.4)
        if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            repeat
                task.wait()
                plr.Character.HumanoidRootPart.CFrame = oldPos
            until (plr.Character.HumanoidRootPart.Position - oldPos.Position).Magnitude < 3
        end
    end,
})

