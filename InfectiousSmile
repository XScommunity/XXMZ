HumanBox:AddDivider()

local killAllV2Running = false
local killAllV2CurrentTarget = nil
local killAllV2Platform = nil

local function createUnderPlatform()
    pcall(function()
        if killAllV2Platform then
            killAllV2Platform:Destroy()
            killAllV2Platform = nil
        end
    end)

    local myChar = plr.Character
    if not myChar then return nil end
    local myHRP = myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    local platform = Instance.new("Part")
    platform.Name = "KillAllV2_Platform"
    platform.Size = Vector3.new(8, 1, 8)
    platform.Anchored = true
    platform.CanCollide = true
    platform.Transparency = 1
    platform.CanQuery = false
    platform.CanTouch = false
    platform.Parent = workspace

    killAllV2Platform = platform
    return platform
end

local function updatePlatformUnderTarget(targetHRP)
    if not killAllV2Platform or not killAllV2Platform.Parent then return end
    if not targetHRP or not targetHRP.Parent then return end

    local feetPos = targetHRP.Position - Vector3.new(0, 3, 0)
    killAllV2Platform.CFrame = CFrame.new(feetPos.X, feetPos.Y - 4.5, feetPos.Z)
end

local function destroyV2Platform()
    pcall(function()
        if killAllV2Platform then
            killAllV2Platform:Destroy()
            killAllV2Platform = nil
        end
    end)
end

