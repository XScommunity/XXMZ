                killAllV3CurrentTarget = enemies[1]
                local target = killAllV3CurrentTarget
                local targetName = target.Name

                Library:Notify({
                    Title = "Kill All V3",
                    Description = "Targeting: " .. targetName,
                    Time = 2,
                })

                createOverPlatform()

                while killAllV3Running and Toggles.KillAllV3Toggle.Value do
                    if not target or not target.Parent then
                        Library:Notify({
                            Title = "Kill All V3",
                            Description = targetName .. " left, switching target...",
                            Time = 2,
                        })
                        destroyV3Platform()
                        break
                    end

                    if target.Character then
                        local targetHumanoid = target.Character:FindFirstChildOfClass("Humanoid")
                        if not targetHumanoid or targetHumanoid.Health <= 0 then
                            Library:Notify({
                                Title = "Kill All V3",
                                Description = targetName .. " killed! Next target...",
                                Time = 2,
                            })
                            destroyV3Platform()
                            break
                        end
                    end

                    local myChar = plr.Character
                    if not myChar then
                        task.wait(1)
                        continue
                    end
                    local myHumanoid = myChar:FindFirstChildOfClass("Humanoid")
                    if not myHumanoid or myHumanoid.Health <= 0 then
                        destroyV3Platform()
                        task.wait(3)
                        continue
                    end

                    local currentTool = myChar:FindFirstChildOfClass("Tool")
                    if not currentTool then
                        local success = grabWeapon()
                        if not success then
                            task.wait(0.5)
                            continue
                        end
                        task.wait(0.3)
                        currentTool = myChar:FindFirstChildOfClass("Tool")
                    end

                    if not currentTool then
                        if myHumanoid then
                            myHumanoid.Health = 0
                        end
                        destroyV3Platform()
                        task.wait(3)
                        continue
                    end

                    for _, part in currentTool:GetDescendants() do
                        if part:IsA("BasePart") and part:FindFirstChild("TouchInterest") then
                            part.Size = Vector3.new(savedHitboxSize, savedHitboxSize, savedHitboxSize)
                            part.Transparency = 0.7
                            part.Massless = true
                        end
                    end

                    if target.Character then
                        local targetHRP = target.Character:FindFirstChild("HumanoidRootPart")
                        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
                        if targetHRP and myHRP then
                            -- POR CIMA: +6.5 acima do HRP (cabeça do alvo)
                            local overPos = targetHRP.Position + Vector3.new(0, 6.5, 0)
                            -- Olha pra baixo no alvo
                            myHRP.CFrame = CFrame.new(overPos, targetHRP.Position)

                            updatePlatformOverTarget(targetHRP)
                        end
                    end

                    pcall(function()
                        local swingEvent = currentTool:FindFirstChild("SwingEvent")
                        if swingEvent then
                            swingEvent:FireServer()
                        end
                    end)

                    task.wait(0.05)
                end

                killAllV3CurrentTarget = nil
                destroyV3Platform()
                task.wait(0.5)
            end
            destroyV3Platform()
        end)
    end,
})

