-- helper
local function getAllTools()
    local tools = {}
    if plr.Character then
        for _, item in plr.Character:GetChildren() do
            if item:IsA("Tool") then table.insert(tools, item) end
        end
    end
    for _, item in plr.Backpack:GetChildren() do
        if item:IsA("Tool") then table.insert(tools, item) end
    end
    return tools
end

