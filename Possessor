--  POSSESSOR ESP
-- ══════════════════════════════════════════
local EspGroup = Tabs.Possessor:AddLeftGroupbox("ESP", "eye")

local highlights  = {}
local espEnabled  = false

local function addHighlight(model, playerName)
    if highlights[model] then return end

    -- Highlight fino (outline only, sem fill pesado)
    local hl = Instance.new("Highlight")
    hl.FillColor           = Color3.fromRGB(20, 20, 20)
    hl.OutlineColor        = Color3.fromRGB(255, 60, 60)
    hl.FillTransparency    = 0.85
    hl.OutlineTransparency = 0
    hl.Adornee             = model
    hl.Parent              = model

    -- BillboardGui com fonte monoespacada
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    local bill = Instance.new("BillboardGui")
    bill.Adornee    = hrp
    bill.Parent     = hrp
    bill.Size       = UDim2.new(0, 180, 0, 44)
    bill.StudsOffset = Vector3.new(0, 3.2, 0)
    bill.AlwaysOnTop = true

    -- Frame de fundo semitransparente
    local bg = Instance.new("Frame", bill)
    bg.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    bg.BackgroundTransparency = 0.45
    bg.BorderSizePixel = 0
    bg.Size = UDim2.new(1, 0, 1, 0)

    local corner = Instance.new("UICorner", bg)
    corner.CornerRadius = UDim.new(0, 4)

    local stroke = Instance.new("UIStroke", bg)
    stroke.Color = Color3.fromRGB(255, 60, 60)
    stroke.Thickness = 1
    stroke.Transparency = 0.3

    -- Tag "POSSESSOR"
    local tag = Instance.new("TextLabel", bg)
    tag.BackgroundTransparency = 1
    tag.Size    = UDim2.new(1, 0, 0.5, 0)
    tag.Position = UDim2.new(0, 0, 0, 0)
    tag.Text    = "[ POSSESSOR ]"
    tag.TextColor3 = Color3.fromRGB(255, 70, 70)
    tag.TextStrokeTransparency = 0.5
    tag.TextStrokeColor3 = Color3.new(0, 0, 0)
    tag.Font    = Enum.Font.RobotoMono
    tag.TextSize = 13
    tag.TextXAlignment = Enum.TextXAlignment.Center

    -- Nome do jogador
    local nameLabel = Instance.new("TextLabel", bg)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Size    = UDim2.new(1, 0, 0.5, 0)
    nameLabel.Position = UDim2.new(0, 0, 0.5, 0)
    nameLabel.Text    = playerName
    nameLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    nameLabel.TextStrokeTransparency = 0.6
    nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    nameLabel.Font    = Enum.Font.RobotoMono
    nameLabel.TextSize = 12
    nameLabel.TextXAlignment = Enum.TextXAlignment.Center

    highlights[model] = { hl = hl, bill = bill }
end

local function removeHighlight(model)
    if not highlights[model] then return end
    highlights[model].hl:Destroy()
    highlights[model].bill:Destroy()
    highlights[model] = nil
end

EspGroup:AddToggle("PossessorESP", {
    Text    = "Possessor ESP",
    Default = false,
    Callback = function(v)
        espEnabled = v
        if not v then
            for m in pairs(highlights) do removeHighlight(m) end
        end
    end,
})

task.spawn(function()
    while task.wait(0.5) do
        if not espEnabled then continue end

        -- Limpa highlights antigos
        for m in pairs(highlights) do removeHighlight(m) end

        for _, plr in pairs(game.Players:GetPlayers()) do
            local real = plr.Character
            if not real then continue end
            for _, obj in pairs(workspace:GetChildren()) do
                if  obj:IsA("Model")
                and obj.Name == plr.Name
                and obj ~= real
                and obj:FindFirstChild("HumanoidRootPart")
                then
                    addHighlight(obj, plr.Name)
                end
            end
        end
    end
end)

