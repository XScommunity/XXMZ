--  PLAYER
-- ══════════════════════════════════════════
local PlayerGroup = Tabs.Player:AddLeftGroupbox("Movement", "zap")

local wsEnabled   = false
local targetSpeed = 16
local allowJump   = false

PlayerGroup:AddToggle("WalkSpeedToggle", {
    Text    = "WalkSpeed",
    Default = false,
    Callback = function(v)
        wsEnabled = v
        -- Ao desativar, restaura velocidade padrão
        if not v then
            local char = game.Players.LocalPlayer.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if hum then hum.WalkSpeed = 16 end
        end
    end,
})

PlayerGroup:AddSlider("WalkSpeedSlider", {
    Text    = "Speed value",
    Default = 16,
    Min     = 16,
    Max     = 80,
    Rounding = 1,
    Callback = function(v)
        targetSpeed = v
    end,
})

PlayerGroup:AddToggle("AllowJump", {
    Text    = "Allow Jump",
    Default = false,
    Callback = function(v)
        allowJump = v
        if not v then
            local char = game.Players.LocalPlayer.Character
            local hum  = char and char:FindFirstChildOfClass("Humanoid")
            if hum then hum.JumpPower = 0 end
        end
    end,
})

-- Loop de manutenção — só aplica se o toggle estiver ativo
game:GetService("RunService").Heartbeat:Connect(function()
    local char = game.Players.LocalPlayer.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    if wsEnabled then
        hum.WalkSpeed = targetSpeed
    end

    hum.JumpPower = allowJump and 50 or 0
end)

-- FullBright
local VisualGroup = Tabs.Player:AddRightGroupbox("Visuals", "sun")

local originalAmbient    = game:GetService("Lighting").Ambient
local originalBrightness = game:GetService("Lighting").Brightness
local originalFogEnd     = game:GetService("Lighting").FogEnd

VisualGroup:AddToggle("FullBright", {
    Text    = "FullBright",
    Default = false,
    Callback = function(v)
        local L = game:GetService("Lighting")
        if v then
            L.Brightness = 2
            L.Ambient    = Color3.fromRGB(178, 178, 178)
        else
            L.Brightness = originalBrightness
            L.Ambient    = originalAmbient
        end
    end,
})

VisualGroup:AddToggle("NoFog", {
    Text    = "No Fog",
    Default = false,
    Callback = function(v)
        game:GetService("Lighting").FogEnd = v and 1e9 or originalFogEnd
    end,
})

VisualGroup:AddSlider("FOVSlider", {
    Text     = "Field of View",
    Default  = 70,
    Min      = 70,
    Max      = 120,
    Rounding = 0,
    Callback = function(v)
        workspace.CurrentCamera.FieldOfView = v
    end,
})

