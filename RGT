-- AUTO HOST SECTION
local HostGroupBox = Tabs.Main:AddRightGroupbox("Auto Host", "crown")

-- Function to check if a player is host by DisplayName color
local function IsPlayerHost(player)
	local character = player.Character
	if not character then return false end
	
	local head = character:FindFirstChild("Head")
	if not head then return false end
	
	local overhead = head:FindFirstChild("OverHead")
	if not overhead then return false end
	
	local container = overhead:FindFirstChild("Container")
	if not container then return false end
	
	local displayName = container:FindFirstChild("DisplayName")
	if not displayName then return false end
	
	-- Check if it's a TextLabel or TextButton
	if displayName:IsA("TextLabel") or displayName:IsA("TextButton") then
		local color = displayName.TextColor3
		local hostColor = Color3.fromRGB(245, 255, 232)
		
		-- Compare colors with small tolerance
		local tolerance = 0.01
		if math.abs(color.R - hostColor.R) < tolerance and 
		   math.abs(color.G - hostColor.G) < tolerance and 
		   math.abs(color.B - hostColor.B) < tolerance then
			return true
		end
	end
	
	return false
end

-- Function to check if there's any host in the server
local function IsThereAHost()
	for _, player in ipairs(Players:GetPlayers()) do
		if IsPlayerHost(player) then
			return true, player
		end
	end
	return false, nil
end

-- Function to request host
local function RequestHost()
	local args = {
		"Host"
	}
	
	local success, err = pcall(function()
		ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ChangeTeam"):FireServer(unpack(args))
	end)
	
	return success, err
end

-- Auto Host Toggle
local autoHostRunning = false
local autoHostConnection = nil

HostGroupBox:AddToggle("AutoHost", {
	Text = "Auto Host",
	Tooltip = "Automatically become host when there's no host",
	Default = false,
	Risky = true,
	
	Callback = function(Value)
		autoHostRunning = Value
		
		if Value then
			Library:Notify({
				Title = "Auto Host Enabled",
				Description = "Monitoring for host availability...",
				Time = 3,
			})
			
			-- Start monitoring
			autoHostConnection = task.spawn(function()
				while autoHostRunning do
					local hasHost, hostPlayer = IsThereAHost()
					
					if not hasHost then
						-- No host found, spam request
						local success, err = RequestHost()
						
						if success then
							print("[Auto Host] Sent host request (no host detected)")
						else
							warn("[Auto Host] Failed to send host request:", err)
						end
						
						task.wait(0.5) -- Spam every 0.5 seconds when no host
					else
						-- Host exists, check less frequently
						print("[Auto Host] Host detected:", hostPlayer.DisplayName .. " (@" .. hostPlayer.Name .. ")")
						task.wait(2) -- Check every 2 seconds when host exists
					end
					
					if Library.Unloaded then
						break
					end
				end
			end)
		else
			Library:Notify({
				Title = "Auto Host Disabled",
				Description = "Stopped monitoring for host",
				Time = 2,
			})
		end
	end,
})

-- Add label to show current host status
HostGroupBox:AddLabel("CurrentHostLabel", {
