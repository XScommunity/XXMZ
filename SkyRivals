-- ========================
-- LOOP PRINCIPAL
-- ========================
RunService.Heartbeat:Connect(function(deltaTime)
    -- Atualiza referências do personagem
    if not Character or not Character.Parent then
        Character = LocalPlayer.Character
    end
    if Character then
        HumanoidRootPart = Character:FindFirstChild("HumanoidRootPart")
        Humanoid = Character:FindFirstChild("Humanoid")
    end

    -- TP Walk Suave (estilo Infinite Yield)
    if TPWalkEnabled and Humanoid and HumanoidRootPart and Humanoid.MoveDirection.Magnitude > 0 then
        local moveDir = Humanoid.MoveDirection.Unit
        local speed = TPWalkSpeed * 18 * deltaTime   -- 18 é um valor bom para ficar natural
        HumanoidRootPart.CFrame = HumanoidRootPart.CFrame + (moveDir * speed)
    end

    -- Kill Aura
    if KillAuraEnabled and Character and HumanoidRootPart then
        local toolName = GetEquippedToolName()
        local tool = GetEquippedTool()
        
        if tool and toolName then
            local isWeapon = not string.find(string.lower(toolName), "pickaxe") and not string.find(string.lower(toolName), "axe")
            
            if isWeapon then
                for _, player in pairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and player.Character then
                        local targetHRP = player.Character:FindFirstChild("HumanoidRootPart")
                        local targetHumanoid = player.Character:FindFirstChild("Humanoid")
                        
                        if targetHRP and targetHumanoid and targetHumanoid.Health > 0 then
                            local distance = (HumanoidRootPart.Position - targetHRP.Position).Magnitude
                            
                            if distance <= KillAuraRange then
                                local parts = {"Left Arm", "Right Arm", "Left Leg", "Right Leg", "Torso", "Head"}
                                local randomPart = parts[math.random(1, #parts)]
                                local targetPart = player.Character:FindFirstChild(randomPart) or player.Character:FindFirstChild("Torso")
                                
                                local hitSound = tool:FindFirstChild("Handle") and tool.Handle:FindFirstChild("Hit")
                                
                                local args = {
                                    HumanoidRootPart.Position,
                                    targetPart,
                                    targetHRP.Position,
                                    toolName,
                                    {
                                        Type = "Melee",
                                        FireAdd = 0,
                                        Damage = 17,
                                        LastYVel = 0.059,
                                        KnockbackTime = 0.15,
                                        Knockback = 12,
                                        MeleeOrigin = HumanoidRootPart.Position,
                                        NewYVel = 0.0001,
                                        HitEffectsForMe = true,
                                        Sound = hitSound,
                                        BloodData = { Enabled = true, Blood1 = true }
                                    }
                                }
                                
                                pcall(function()
                                    ReplicatedStorage.Remotes.ValidateHit:FireServer(unpack(args))
                                end)
                                
                                task.wait(0.25)
                            end
                        end
                    end
                end
            end
        end
    end

    -- ESP Items
    if ESPItemsEnabled and Workspace:FindFirstChild("DroppedItems") then
        for _, item in pairs(Workspace.DroppedItems:GetChildren()) do
            if (item:IsA("BasePart") or item:IsA("Model")) and not ItemESPs[item] then
                ItemESPs[item] = CreateESP(item, Color3.fromRGB(255, 215, 0), "📦 " .. item.Name)
            end
        end
        for item, esp in pairs(ItemESPs) do
            if not item or not item.Parent then
                if esp then esp:Destroy() end
                if item then local t = item:FindFirstChild("BlockGameESPText") if t then t:Destroy() end end
                ItemESPs[item] = nil
            end
        end
    end

    -- ESP Players
    if ESPPlayersEnabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                if hrp then
                    if not PlayerESPs[player] or not PlayerESPs[player].Parent then
                        local inventory = "🎒 Vazio"
                        if player:FindFirstChild("Backpack") then
                            local items = {}
                            for _, tool in pairs(player.Backpack:GetChildren()) do
                                if tool:IsA("Tool") then table.insert(items, tool.Name) end
                            end
                            if #items > 0 then inventory = "🎒 " .. table.concat(items, ", ") end
                        end
                        local distance = math.floor((HumanoidRootPart.Position - hrp.Position).Magnitude)
                        PlayerESPs[player] = CreateESP(hrp, Color3.fromRGB(255, 255, 255), player.Name .. "\n" .. inventory .. "\n" .. distance .. "m")
                    else
                        local textESP = hrp:FindFirstChild("BlockGameESPText")
                        if textESP and textESP:FindFirstChild("TextLabel") then
                            local inventory = "🎒 Vazio"
                            if player:FindFirstChild("Backpack") then
                                local items = {}
                                for _, tool in pairs(player.Backpack:GetChildren()) do
                                    if tool:IsA("Tool") then table.insert(items, tool.Name) end
                                end
                                if #items > 0 then inventory = "🎒 " .. table.concat(items, ", ") end
                            end
                            local distance = math.floor((HumanoidRootPart.Position - hrp.Position).Magnitude)
                            textESP.TextLabel.Text = player.Name .. "\n" .. inventory .. "\n" .. distance .. "m"
                        end
                    end
                end
            end
        end
        
        for player, esp in pairs(PlayerESPs) do
            if not player or not player.Parent or not player.Character then
                if esp then esp:Destroy() end
                PlayerESPs[player] = nil
            end
        end
    end

    -- ESP Crates
    if ESPCratesEnabled and Workspace:FindFirstChild("Blocks") then
        local crates = Workspace.Blocks:FindFirstChild("Crates")
        if crates then
            for _, crate in pairs(crates:GetChildren()) do
                if not CrateESPs[crate] then
                    CrateESPs[crate] = CreateESP(crate, Color3.fromRGB(0, 255, 127), "📦 Crate")
                end
            end
            for crate, esp in pairs(CrateESPs) do
                if not crate or not crate.Parent then
                    if esp then esp:Destroy() end
                    if crate then local t = crate:FindFirstChild("BlockGameESPText") if t then t:Destroy() end end
                    CrateESPs[crate] = nil
                end
            end
        end
    end
end)

