-- ============================================
-- PILOT STATE (declarado antes de stopAll)
-- ============================================
local PilotState = {
    CurrentAlt = 0,
    Conn       = nil,
}

-- ============================================
-- CONFIGS
-- ============================================
local CONFIG = {
    ReplayInterval  = 1,
    TalkInterval    = 5,
    RetrySeatDelay  = 2,
}

local Running = true
local ActiveLoops = {}

local function stopAll()
    Running = false
    for _, conn in ipairs(ActiveLoops) do
        pcall(function() conn:Disconnect() end)
    end
    if PilotState.Conn then
        pcall(function() PilotState.Conn:Disconnect() end)
    end
    if ScreenGui then
        pcall(function() ScreenGui:Destroy() end)
    end
    -- Deleta o arquivo do autoexec
    pcall(function() delfile("autoexec/autofarm_loader.lua") end)
    pcall(function() delfile("autoexec/XXMZ_AF_v13.lua") end)
    pcall(function() delfile("autoexec/autofarmXXMZ.lua") end)
    print("[AUTOFARM] PARADO! Arquivo do autoexec deletado.")
end

StopButton.MouseButton1Click:Connect(stopAll)

-- ============================================
-- REMOTES
-- ============================================
local Remotes = RepStorage:WaitForChild("Remotes", 10)
local TooltipAction = Remotes:WaitForChild("TooltipAction", 10)
local ReplayVote    = Remotes:WaitForChild("ReplayVote", 10)
local PilotControl  = Remotes:WaitForChild("PilotControl", 10)

-- ============================================
-- UTILS
-- ============================================
local function safeFire(remote, ...)
    if not remote then return end
    local args = {...}
    pcall(function()
        remote:FireServer(unpack(args))
    end)
end

local function getAltitude()
    local v = Workspace:FindFirstChild("ClientAltitude")
    if v and v:IsA("NumberValue") then return v.Value end
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj.Name == "ClientAltitude" and obj:IsA("NumberValue") then return obj.Value end
    end
    local char = LocalPlayer.Character
    if char then
        local root = char:FindFirstChild("HumanoidRootPart")
        if root then return root.Position.Y end
    end
    return 0
end

-- ============================================
-- 1. AUTO REPLAY VOTE
-- ============================================
table.insert(ActiveLoops, task.spawn(function()
    while Running do
        if ReplayVote and ReplayVote:IsA("RemoteEvent") then
            safeFire(ReplayVote)
        end
        task.wait(CONFIG.ReplayInterval)
    end
end))

-- ============================================
-- 2. AUTO SEAT (PilotSeat)
-- ============================================
local function trySeat()
    pcall(function()
        local seat = Workspace.Plane.Seats.PilotSeat.Seat.Seat
        safeFire(TooltipAction, "Seat", seat)
    end)
end

table.insert(ActiveLoops, task.spawn(function()
    trySeat()
    while Running do
        if not (Humanoid.SeatPart and Humanoid.SeatPart.Name:lower():find("pilot")) then
            trySeat()
        end
        task.wait(CONFIG.RetrySeatDelay)
    end
end))

LocalPlayer.CharacterAdded:Connect(function(newChar)
    Character = newChar
    Humanoid = newChar:WaitForChild("Humanoid")
    task.wait(2)
    trySeat()
end)

-- ============================================
-- 3. AI PILOT (SEM EVADE — só estabiliza altitude)
-- ============================================

local function onStep()
    if not Running then return end
    local prevAlt = PilotState.CurrentAlt
    PilotState.CurrentAlt = getAltitude()
    local altDelta = PilotState.CurrentAlt - prevAlt

    if altDelta < -0.5 then
        safeFire(PilotControl, "pitch", "up", 1)
    elseif altDelta > 0.5 then
        safeFire(PilotControl, "pitch", "down", 1)
    end
end

PilotState.CurrentAlt = getAltitude()
PilotState.Conn = RunService.RenderStepped:Connect(onStep)

-- ============================================
-- 4. AUTO TALK TO PASSENGERS
-- ============================================
table.insert(ActiveLoops, task.spawn(function()
    while Running do
        local ok, passengers = pcall(function()
            return Workspace.Plane.Passengers:GetChildren()
        end)

        if ok and passengers then
            for _, passenger in ipairs(passengers) do
                if passenger:IsA("Model") then
                    task.spawn(function()
                        if Running then
                            safeFire(TooltipAction, "Talk to Passenger", passenger)
                        end
                    end)
                end
            end
        end

        task.wait(CONFIG.TalkInterval)
    end
end))

